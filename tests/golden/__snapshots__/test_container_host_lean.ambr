    <xccdf:benchmark href="/usr/share/xml/scap/ssg/content/ssg-almalinux9-ds.xml"/>
    <xccdf:version time="SNAP">1</xccdf:version>
    <xccdf:Profile id="xccdf_ks-gen_profile_tailored" extends="xccdf_org.ssgproject.content_profile_stig">
      <xccdf:title xml:lang="en-US">ks-gen tailored xccdf_org.ssgproject.content_profile_stig</xccdf:title>
      <xccdf:description xml:lang="en-US">Tailoring generated by ks-gen.</xccdf:description>
      <xccdf:set-value idref="xccdf_org.ssgproject.content_value_var_auditd_disk_full_action">SUSPEND</xccdf:set-value>
      <xccdf:set-value idref="xccdf_org.ssgproject.content_value_var_auditd_disk_error_action">SUSPEND</xccdf:set-value>
      <xccdf:set-value idref="xccdf_org.ssgproject.content_value_var_auditd_max_log_file_action">ROTATE</xccdf:set-value>
      <xccdf:select idref="xccdf_org.ssgproject.content_rule_banner_etc_issue" selected="false"/>
      <xccdf:select idref="xccdf_org.ssgproject.content_rule_banner_etc_issue_net" selected="false"/>
      <xccdf:select idref="xccdf_org.ssgproject.content_rule_dconf_gnome_banner_enabled" selected="false"/>
      <xccdf:select idref="xccdf_org.ssgproject.content_rule_enable_fips_mode" selected="false"/>
      <xccdf:select idref="xccdf_org.ssgproject.content_rule_sshd_use_approved_ciphers" selected="false"/>
      <xccdf:select idref="xccdf_org.ssgproject.content_rule_sshd_use_approved_kex" selected="false"/>
      <xccdf:select idref="xccdf_org.ssgproject.content_rule_sshd_use_approved_macs" selected="false"/>
      <xccdf:select idref="xccdf_org.ssgproject.content_rule_sshd_use_approved_mac_ordered" selected="false"/>
      <xccdf:select idref="xccdf_org.ssgproject.content_rule_install_DoD_intermediate_certificates" selected="false"/>
      <xccdf:set-value idref="xccdf_org.ssgproject.content_value_var_accounts_passwords_pam_faillock_unlock_time">900</xccdf:set-value>
      <xccdf:set-value idref="xccdf_org.ssgproject.content_value_var_accounts_passwords_pam_faillock_deny">3</xccdf:set-value>
      <xccdf:select idref="xccdf_org.ssgproject.content_rule_accounts_passwords_pam_faillock_even_deny_root" selected="false"/>
      <xccdf:select idref="xccdf_org.ssgproject.content_rule_package_usbguard_installed" selected="false"/>
      <xccdf:select idref="xccdf_org.ssgproject.content_rule_service_usbguard_enabled" selected="false"/>
      <xccdf:select idref="xccdf_org.ssgproject.content_rule_configure_usbguard_auditbackend" selected="false"/>
    </xccdf:Profile>
  </xccdf:Tailoring>
  
  '''
