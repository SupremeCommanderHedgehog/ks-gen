# ---
# name: test_ubuntu_minimal[user-data]
  '''
  #cloud-config
  autoinstall:
    version: 1
    identity:
      hostname: "u24-min"
      realname: "opsadmin"
      username: "opsadmin"
      password: "*"
    user-data:
      users:
        - name: "opsadmin"
          sudo: "ALL=(ALL) NOPASSWD:ALL"
          shell: /bin/bash
          ssh_authorized_keys:
            - "ssh-ed25519 AAAA a@b"
    packages:
      - "ufw"
    late-commands:
    - |
      curtin in-target --target=/target -- bash -c '# rule:ssh_keep_open
      ufw allow 22/tcp'
  
  '''
# ---
