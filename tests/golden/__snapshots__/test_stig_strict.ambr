# name: test_stig_strict[ks.cfg]
  '''
  # Generated by ks-gen vSNAP on SNAP
  # Source profile: xccdf_org.ssgproject.content_profile_stig
  # DO NOT EDIT by hand — regenerate with `ks-gen gen --config <yaml>`
  
  text
  lang en_US.UTF-8
  keyboard us
  timezone UTC --utc
  
  network --device=link --bootproto=dhcp --hostname=stig01.example.com --onboot=yes
  
  rootpw --lock
  bootloader --location=mbr --append="audit=1 audit_backlog_limit=8192 fips=1"
  
  zerombr
  clearpart --all --initlabel
  part /boot/efi --fstype=efi --size=1024 --asprimary
  part /boot --fstype=xfs --size=1024 --fsoptions="nodev,nosuid" --asprimary
  part pv.01 --grow --size=1
  volgroup vg_root pv.01
  logvol /             --vgname=vg_root --name=root     --fstype=xfs --size=15360
  logvol /home         --vgname=vg_root --name=home     --fstype=xfs --size=5120  --fsoptions="nodev,nosuid"
  logvol /tmp          --vgname=vg_root --name=tmp      --fstype=xfs --size=3072  --fsoptions="nodev,nosuid,noexec"
  logvol /var          --vgname=vg_root --name=var      --fstype=xfs --size=10240 --fsoptions="nodev"
  logvol /var/log      --vgname=vg_root --name=varlog   --fstype=xfs --size=5120  --fsoptions="nodev,nosuid,noexec"
  logvol /var/log/audit --vgname=vg_root --name=varlogaudit --fstype=xfs --size=3072 --fsoptions="nodev,nosuid,noexec"
  logvol /var/tmp      --vgname=vg_root --name=vartmp   --fstype=xfs --size=2048  --fsoptions="nodev,nosuid,noexec"
  logvol swap          --vgname=vg_root --name=swap     --fstype=swap --recommended
  
  services --enabled=chronyd,firewalld,auditd,rsyslog,sshd
  authselect select sssd --force
  
  %pre --erroronfail --log=/tmp/ks-pre-tailoring.log
  set -euo pipefail
  
  # oscap-anaconda-addon resolves tailoring-path inside its content staging dir
  # /tmp/openscap_data, not the installer-FS root. Create it and write here.
  mkdir -p /tmp/openscap_data
  
  if [ -s /tmp/openscap_data/tailoring.xml ]; then
    echo "ks-gen: /tmp/openscap_data/tailoring.xml already present, skipping fetch"
    exit 0
  fi
  
  ks_arg=$(awk -F'inst.ks=' 'NF>1{print $2}' /proc/cmdline | awk '{print $1}')
  case "$ks_arg" in
    http://*|https://*)
      base="${ks_arg%/*}"
      curl -fsSL --retry 5 --retry-delay 3 "${base}/tailoring.xml" -o /tmp/openscap_data/tailoring.xml
      ;;
    hd:*)
      cp -f /run/install/repo/tailoring.xml /tmp/openscap_data/tailoring.xml || {
        echo "ks-gen: failed to copy tailoring.xml from /run/install/repo" >&2
        exit 1
      }
      ;;
    *)
      echo "ks-gen: unsupported inst.ks transport '$ks_arg'; cannot fetch tailoring.xml" >&2
      exit 1
      ;;
  esac
  
  test -s /tmp/openscap_data/tailoring.xml
  head -c 5 /tmp/openscap_data/tailoring.xml | grep -q '<?xml'
  %end
  
  %packages
  @^minimal-environment
  @standard
  scap-security-guide
  openscap-scanner
  oscap-anaconda-addon
  aide
  audit
  rsyslog
  chrony
  firewalld
  sudo
  policycoreutils-python-utils
  -telnet-server
  -rsh-server
  -tftp-server
  -vsftpd
  -ypserv
  %end
  
  %addon org_fedora_oscap
    content-type = scap-security-guide
    profile = xccdf_org.ssgproject.content_profile_stig
    tailoring-path = /tailoring.xml
  %end
  
  %post --erroronfail --log=/root/ks-post.log
  set -euxo pipefail
  
  # ===== admin_user_and_keys =====
  # Create admin user (idempotent)
  if ! getent passwd stigops >/dev/null 2>&1; then
    useradd --create-home --shell /bin/bash --groups wheel --comment "" stigops
  fi
  passwd -l stigops
  
  install -d -m 700 -o stigops -g stigops /home/stigops/.ssh
  cat > /home/stigops/.ssh/authorized_keys <<'__KS_GEN_EOF__'
  ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAITESTKEYstigstrict ops@bastion
  __KS_GEN_EOF__
  chmod 600 /home/stigops/.ssh/authorized_keys
  chown stigops:stigops /home/stigops/.ssh/authorized_keys
  restorecon -R /home/stigops/.ssh
  
  # Sudoers
  cat > /etc/sudoers.d/00-ks-gen-admin <<'__KS_GEN_EOF__'
  stigops ALL=(ALL) ALL
  __KS_GEN_EOF__
  chmod 440 /etc/sudoers.d/00-ks-gen-admin
  visudo -cf /etc/sudoers.d/00-ks-gen-admin
  
  # ===== auditd_actions =====
  # Re-assert auditd actions
  sed -i -E 's|^disk_full_action.*|disk_full_action = HALT|' /etc/audit/auditd.conf
  sed -i -E 's|^disk_error_action.*|disk_error_action = HALT|' /etc/audit/auditd.conf
  sed -i -E 's|^max_log_file_action.*|max_log_file_action = keep_logs|' /etc/audit/auditd.conf
  
  # ===== banner_text =====
  # Civilian-equivalent login banner
  cat > /etc/issue <<'__KS_GEN_EOF__'
  WARNING: This is a private computer system. Unauthorized access is
  prohibited. All activity on this system may be monitored and logged.
  Use of this system constitutes consent to such monitoring.
  __KS_GEN_EOF__
  chmod 644 /etc/issue
  cat > /etc/issue.net <<'__KS_GEN_EOF__'
  WARNING: This is a private computer system. Unauthorized access is
  prohibited. All activity on this system may be monitored and logged.
  Use of this system constitutes consent to such monitoring.
  __KS_GEN_EOF__
  chmod 644 /etc/issue.net
  cat > /etc/motd <<'__KS_GEN_EOF__'
  WARNING: This is a private computer system. Unauthorized access is
  prohibited. All activity on this system may be monitored and logged.
  Use of this system constitutes consent to such monitoring.
  __KS_GEN_EOF__
  chmod 644 /etc/motd
  
  # ===== crypto_policy =====
  # Apply system-wide crypto policy: STIG (FIPS)
  update-crypto-policies --set FIPS
  
  # ===== faillock_safety =====
  # Re-assert faillock.conf in case oscap over-tightened
  sed -i -E 's/^[# ]*unlock_time *=.*/unlock_time = 0/' /etc/security/faillock.conf
  grep -q '^unlock_time' /etc/security/faillock.conf || echo 'unlock_time = 0' >> /etc/security/faillock.conf
  sed -i -E 's/^[# ]*deny *=.*/deny = 3/' /etc/security/faillock.conf
  grep -q '^deny' /etc/security/faillock.conf || echo 'deny = 3' >> /etc/security/faillock.conf
  sed -i -E 's/^[# ]*even_deny_root.*/# even_deny_root removed by ks-gen: yes/' /etc/security/faillock.conf
  
  # ===== kernel_module_blacklist =====
  # Disable specific kernel modules via modprobe install-trick
  cat > /etc/modprobe.d/ks-gen-blacklist.conf <<'__KS_GEN_EOF__'
  install usb-storage /bin/true
  install cramfs /bin/true
  install freevxfs /bin/true
  install jffs2 /bin/true
  install hfs /bin/true
  install hfsplus /bin/true
  install squashfs /bin/true
  install udf /bin/true
  __KS_GEN_EOF__
  chmod 644 /etc/modprobe.d/ks-gen-blacklist.conf
  
  # ===== package_purge =====
  # Remove disallowed packages (no-op if not installed)
  dnf -y remove telnet-server rsh-server tftp-server vsftpd ypserv || true
  
  # ===== ssh_keep_open =====
  # Pre-open SSH port in firewalld + SELinux (before sshd starts on first boot)
  firewall-offline-cmd --add-port=22/tcp
  
  # ===== ssh_config_apply =====
  # Drop-in SSH server config (active on first boot)
  install -d -m 755 /etc/ssh/sshd_config.d
  cat > /etc/ssh/sshd_config.d/00-ks-gen.conf <<'__KS_GEN_EOF__'
  Port 22
  PermitRootLogin no
  PasswordAuthentication no
  ClientAliveInterval 600
  ClientAliveCountMax 1
  MaxAuthTries 4
  UsePAM yes
  __KS_GEN_EOF__
  chmod 600 /etc/ssh/sshd_config.d/00-ks-gen.conf
  sshd -t
  
  # ===== time_servers =====
  # Chrony configuration (servers from host.yaml; STIG-compliant base)
  cat > /etc/chrony.conf <<'__KS_GEN_EOF__'
  server pool.ntp.org iburst
  driftfile /var/lib/chrony/drift
  makestep 1.0 3
  rtcsync
  logdir /var/log/chrony
  __KS_GEN_EOF__
  chmod 644 /etc/chrony.conf
  
  %end
  
  reboot --eject
  
  '''
